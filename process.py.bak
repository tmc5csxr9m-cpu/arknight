#!/usr/bin/env python3
# SPDX-License-Identifier: AGPL-3.0-only
import argparse
import importlib.util
from pathlib import Path
from PIL import Image


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser()
    parser.add_argument(
        "config",
        nargs="?",
        default="config.py",
        help="Path to original config.py",
    )
    parser.add_argument(
        "--out-dir",
        default="processed_png",
        help="Directory for processed PNG files",
    )
    parser.add_argument(
        "--out-config",
        default="processed_config.py",
        help="Output config file",
    )
    return parser.parse_args()


def load_config(config_path: Path) -> dict[str, str]:
    config_path = config_path.expanduser().resolve()

    if not config_path.exists():
        raise FileNotFoundError(f"config not found: {config_path}")

    spec = importlib.util.spec_from_file_location("user_config", config_path)
    if spec is None or spec.loader is None:
        raise RuntimeError(f"cannot load config: {config_path}")

    module = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(module)

    data = getattr(module, "myconfig", None)
    if not isinstance(data, dict) or not data:
        raise RuntimeError("config must contain: myconfig = {image_path: audio_path, ...}")

    base_dir = config_path.parent
    result = {}

    for img, audio in data.items():
        img_path = Path(str(img)).expanduser()
        audio_path = Path(str(audio)).expanduser()

        if not img_path.is_absolute():
            img_path = base_dir / img_path

        if not audio_path.is_absolute():
            audio_path = base_dir / audio_path

        result[str(img_path.resolve())] = str(audio_path.resolve())

    return result


def unique_output_path(out_dir: Path, src: Path) -> Path:
    base = src.stem
    suffix = "_cropped.png"

    candidate = out_dir / f"{base}{suffix}"

    index = 1
    while candidate.exists():
        candidate = out_dir / f"{base}_{index}{suffix}"
        index += 1

    return candidate


def crop_alpha_zero_border(src: Path, dst: Path) -> tuple[int, int, int, int]:
    img = Image.open(src).convert("RGBA")
    bbox = img.getchannel("A").getbbox()

    if bbox is None:
        raise RuntimeError(f"fully transparent image: {src}")

    cropped = img.crop(bbox)

    dst.parent.mkdir(parents=True, exist_ok=True)

    # 不做调色、不预乘、不改 Alpha，只裁掉四周完全透明区域。
    cropped.save(dst, format="PNG")

    return bbox


def write_config(path: Path, data: dict[str, str]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)

    with open(path, "w", encoding="utf-8") as f:
        f.write("# Generated by preprocess_png.py\n")
        f.write("myconfig = {\n")

        for img, audio in data.items():
            f.write(f"    {img!r}: {audio!r},\n")

        f.write("}\n")


def main() -> int:
    args = parse_args()

    config_path = Path(args.config).expanduser().resolve()
    base_dir = config_path.parent

    out_dir = Path(args.out_dir).expanduser()
    if not out_dir.is_absolute():
        out_dir = base_dir / out_dir

    out_config = Path(args.out_config).expanduser()
    if not out_config.is_absolute():
        out_config = base_dir / out_config

    config = load_config(config_path)

    new_config: dict[str, str] = {}

    for img_str, audio_str in config.items():
        img = Path(img_str)
        audio = Path(audio_str)

        if not img.exists():
            print(f"[skip] image not found: {img}")
            continue

        if img.suffix.lower() != ".png":
            print(f"[skip] not png: {img}")
            continue

        dst = unique_output_path(out_dir, img)

        try:
            bbox = crop_alpha_zero_border(img, dst)
        except Exception as e:
            print(f"[fail] {img}: {e}")
            continue

        new_config[str(dst.resolve())] = str(audio.resolve())
        print(f"[ok] {img} -> {dst}, bbox={bbox}")

    write_config(out_config, new_config)

    print()
    print(f"written config: {out_config}")
    print(f"processed png dir: {out_dir}")

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
